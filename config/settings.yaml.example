# NetScaler SSL Automation — Settings Template
# ---------------------------------------------------------------
# USAGE: cp config/settings.yaml.example config/settings.yaml
#        Then fill in hostnames/usernames for your environment.
#        config/settings.yaml is git-ignored — never commit it.
#
# PASSWORDS: Never put passwords directly in this file.
#            Use ${ENV_VAR} syntax — values are read from the
#            shell environment at runtime.
#
# Required environment variables:
#   export ADM_PASSWORD=<your Citrix ADM password>
#   export SNOW_PASSWORD=<your ServiceNow password>
#
# Optional:
#   export SMTP_PASSWORD=<SMTP password, only if relay requires auth>
# ---------------------------------------------------------------

# -------------------------------------------------------------------
# State Store
# -------------------------------------------------------------------
# Dev:  SQLite path (relative to project root)
# Prod: PostgreSQL DSN — "postgresql://user:pass@host:5432/ssl_automation"
state_db: "state/jobs.db"

# -------------------------------------------------------------------
# Citrix ADM
# -------------------------------------------------------------------
adm:
  host:       "adm.your-company.local"   # ADM hostname or IP
  username:   "nsroot"                   # ADM service account
  password:   ${ADM_PASSWORD}            # → export ADM_PASSWORD=<value>
  verify_ssl: true                       # false only for self-signed ADM cert

# -------------------------------------------------------------------
# ITSM / Change Management
# -------------------------------------------------------------------
itsm:
  provider:            "servicenow"       # servicenow | jira
  servicenow_instance: "your-company"     # → your-company.service-now.com
  username:            "svc-ssl-auto"     # ServiceNow service account
  password:            ${SNOW_PASSWORD}   # → export SNOW_PASSWORD=<value>

  # Uncomment for Jira instead:
  # provider:          "jira"
  # jira_url:          "https://jira.your-company.local"
  # jira_project_key:  "CHG"
  # username:          "svc-ssl-auto"
  # password:          ${SNOW_PASSWORD}

# -------------------------------------------------------------------
# UAT ADCs (IPs must match what ADM uses as the managed device IP)
# -------------------------------------------------------------------
uat_adcs:
  - "10.0.0.10"    # UAT ADC 1
  - "10.0.0.11"    # UAT ADC 2

uat_vips:
  - host: "uat-vpn.your-company.local"
    port: 443
  - host: "uat-gateway.your-company.local"
    port: 443

# -------------------------------------------------------------------
# Known VIP SANs — leaf cert MUST cover at least one of these
# -------------------------------------------------------------------
known_vip_sans:
  - "vpn.your-company.com"
  - "gateway.your-company.com"
  - "aovpn.your-company.com"

# -------------------------------------------------------------------
# TLS Validation
# -------------------------------------------------------------------
tls_timeout: 10    # seconds per VIP connection attempt

# -------------------------------------------------------------------
# Notifications
# -------------------------------------------------------------------
notifications:
  recipients:
    - "netops@your-company.com"
    - "security@your-company.com"

  # SMTP (leave host blank to disable email)
  smtp:
    host:     "smtp.your-company.local"
    port:     25
    from:     "ssl-automation@your-company.com"
    tls:      false
    username: ""            # Leave blank for unauthenticated relay
    password: ""            # Or: ${SMTP_PASSWORD} if auth required

  # Microsoft Teams incoming webhook (leave blank to disable)
  teams_webhook_url: ""
  # Example: "https://your-company.webhook.office.com/webhookb2/..."
